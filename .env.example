# ============================================================================
# Painel CrowdSec — arquivo de configuração de exemplo.
# Copie para `.env` e ajuste. NUNCA versione o `.env` real.
# ============================================================================

# ----------------------------------------------------------------- CrowdSec DB
# Backend do banco do CrowdSec: sqlite (padrão) | mysql | mariadb
CROWDSEC_DB_TYPE=sqlite
# Caminho do SQLite do CrowdSec (padrão do Debian):
CROWDSEC_DB_PATH=/var/lib/crowdsec/data/crowdsec.db
# A app SEMPRE lê em modo somente-leitura; este flag é informativo.
CROWDSEC_DB_READONLY=1
# Caminho do binário cscli (se não estiver no PATH, ex.: /usr/bin/cscli)
CSCLI_BIN=cscli

# --- Somente se CROWDSEC_DB_TYPE=mysql|mariadb (banco migrado) ---
# CROWDSEC_DB_HOST=127.0.0.1
# CROWDSEC_DB_PORT=3306
# CROWDSEC_DB_USER=crowdsec
# CROWDSEC_DB_PASSWORD=
# CROWDSEC_DB_NAME=crowdsec

# ----------------------------------------------------------------- App / Auth
# Segredo para assinar cookies de sessão. GERE UM FORTE:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=troque-por-um-segredo-forte

ADMIN_USER=admin
# Hash da senha (recomendado). Gere com:
#   python auth.py 'minha-senha-forte'
ADMIN_PASSWORD_HASH=
# Alternativa APENAS para dev (texto plano). Deixe vazio em produção.
# ADMIN_PASSWORD=

HOST=0.0.0.0
PORT=8100
APP_DB_PATH=./data/app.db

# Cookie de sessão
SESSION_COOKIE=csdash_session
SESSION_MAX_AGE=43200
# Defina 1 se servir por HTTPS (recomendado atrás de proxy TLS)
COOKIE_SECURE=0

# ----------------------------------------------------------------- Geolocalização de IP
# Chave da API do iplocation.net (https://www.iplocation.net/signup).
# A busca é sob demanda (botão na tabela) e o resultado fica em cache no app.db.
IPLOCATION_API_KEY=
# TTL do cache de geolocalização em dias (0 = nunca expira).
GEOIP_CACHE_TTL_DAYS=30

# ----------------------------------------------------------------- Logs nginx
# Glob dos logs de acesso (inclui rotacionados e .gz)
NGINX_LOG_GLOB=/var/log/nginx/*access.log*
# Regex do log_format. Padrão = combined (tolerante a requests malformadas,
# ex.: scans/lixo binário que geram 400). Só altere se usar log_format custom.
# Grupos nomeados: ip,user,time,status,size,referer,ua + a request line inteira
# em <request> (o parser a quebra em method/path/proto). Alternativamente, use
# os grupos method/path/proto explicitamente que o parser também os aceita.
# NGINX_LOG_FORMAT_REGEX=

# ----------------------------------------------------------------- Alertas
ALERT_POLL_SECONDS=20
# Origens que disparam alerta (vírgula). CAPI/lists geram muito volume — omita-as.
ALERT_ORIGINS=crowdsec,cscli

# Webhook genérico (HTTP POST JSON)
ALERT_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# E-mail (SMTP) — opcional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Destinatários (vírgula)
SMTP_TO=
SMTP_TLS=1
