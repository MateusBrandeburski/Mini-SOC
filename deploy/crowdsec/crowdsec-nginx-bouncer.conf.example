# Exemplo do /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf
# O pacote `crowdsec-nginx-bouncer` gera este arquivo no apt install e registra
# a API_KEY automaticamente. NÃO versionar a chave real — aqui vai um placeholder.
#
# Este bouncer roda DENTRO do nginx (lua) e bloqueia pelo IP REAL do visitante
# (CF-Connecting-IP, resolvido pelo real_ip) — fecha a brecha do firewall-bouncer,
# que via Cloudflare só enxerga o IP da borda da CF e não bloqueia o atacante.

ENABLED=true
API_URL=http://127.0.0.1:8080
API_KEY=<GERADO_AUTOMATICAMENTE_NO_APT_INSTALL__NAO_VERSIONAR>
USE_TLS_AUTH=false

# stream: pré-carrega as decisões no cache lua e consulta localmente.
# IMPORTANTE: use "stream" (o modo "live" NÃO bloqueou de forma confiável nos testes).
# Após um novo ban, o stream leva até UPDATE_FREQUENCY segundos para propagar.
MODE=stream
UPDATE_FREQUENCY=10
CACHE_EXPIRATION=1

BOUNCING_ON_TYPE=all
FALLBACK_REMEDIATION=ban
REQUEST_TIMEOUT=3000

# Resposta ao IP banido: RET_CODE vazio = 403 + página de ban padrão.
RET_CODE=
BAN_TEMPLATE_PATH=/var/lib/crowdsec/lua/templates/ban.html
REDIRECT_LOCATION=

# Captcha não usado (só ban). O aviso "no recaptcha site key" no log é inofensivo.
SECRET_KEY=
SITE_KEY=

SSL_VERIFY=true
